#!/usr/bin/env python3
"""
Phase 2A – Boruta + SHAP feature ranking on the 13 development users.
Input:
  - ./features/*_training_sessions.csv (only the first 13 dev users used)
  - cleaned_features.csv (from Phase 1)
Output:
  - boruta_shap_ranking.csv   (columns: feature, shap_importance)
"""

import os, glob, warnings
import pandas as pd
import numpy as np
from sklearn.preprocessing import StandardScaler
from xgboost import XGBClassifier
from boruta import BorutaPy
import shap

warnings.filterwarnings('ignore')

# ======================= CONFIGURATION =======================
DATA_DIR = "./features"
CLEANED_FEATURES_FILE = "cleaned_features.csv"
OUTPUT_RANKING = "boruta_shap_ranking.csv"
N_DEV_USERS = 13

# Boruta / XGBoost parameters
XGB_PARAMS = {
    'n_estimators': 100,
    'max_depth': 5,
    'learning_rate': 0.1,
    'objective': 'multi:softmax',
    'num_class': None,          # will be set after counting users
    'n_jobs': -1,
    'random_state': 42
}
BORUTA_MAX_ITER = 100
BORUTA_PERC = 90
# =============================================================

# 1. Identify the 13 development users ---------------------------------------
all_train_files = sorted(glob.glob(os.path.join(DATA_DIR, "*_training_sessions.csv")))
all_users = [os.path.basename(f).replace("_training_sessions.csv", "") for f in all_train_files]
if len(all_users) < N_DEV_USERS:
    raise ValueError(f"Need at least {N_DEV_USERS} users, found {len(all_users)}")

dev_users = all_users[:N_DEV_USERS]
print(f"Development users: {dev_users}")

# 2. Load cleaned feature list -----------------------------------------------
cleaned_df = pd.read_csv(CLEANED_FEATURES_FILE)   # must contain a column 'feature'
if 'feature' not in cleaned_df.columns:
    raise KeyError("cleaned_features.csv must have a 'feature' column")
cleaned_features = cleaned_df['feature'].tolist()
print(f"Using {len(cleaned_features)} cleaned features.")

# 3. Load and combine training data of the dev users (genuine only) -----------
dfs = []
for user in dev_users:
    file_path = os.path.join(DATA_DIR, f"{user}_training_sessions.csv")
    df = pd.read_csv(file_path)
    # Keep only cleaned features that exist in this file
    available_features = [f for f in cleaned_features if f in df.columns]
    if not available_features:
        print(f"Warning: user {user} has no matching cleaned features!")
        continue
    df = df[available_features].copy()
    df['user'] = user
    dfs.append(df)

full_df = pd.concat(dfs, ignore_index=True)
print(f"Combined shape: {full_df.shape}")

# Separate labels and features
y = full_df['user'].astype('category').cat.codes
X = full_df.drop(columns=['user'])

# Ensure numeric and fill missing
X = X.select_dtypes(include=[np.number])
if X.isna().sum().sum() > 0:
    X = X.fillna(0)

feature_names = X.columns.tolist()
print(f"Features for Boruta: {len(feature_names)}")

# Standardise
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)

# 4. Boruta feature selection -------------------------------------------------
num_classes = len(np.unique(y))
xgb_params = XGB_PARAMS.copy()
xgb_params['num_class'] = num_classes

xgb = XGBClassifier(**xgb_params)
feat_selector = BorutaPy(
    xgb,
    n_estimators='auto',
    verbose=2,
    random_state=42,
    max_iter=BORUTA_MAX_ITER,
    perc=BORUTA_PERC
)

print("Running Boruta...")
feat_selector.fit(X_scaled, y)

selected_mask = feat_selector.support_
tentative_mask = feat_selector.support_weak_
selected_features = [feature_names[i] for i in range(len(feature_names)) if selected_mask[i]]
tentative_features = [feature_names[i] for i in range(len(feature_names)) if tentative_mask[i] and not selected_mask[i]]
final_features = selected_features + tentative_features   # keep both to be safe
print(f"Selected: {len(selected_features)}, Tentative: {len(tentative_features)}")

if not final_features:
    raise RuntimeError("No features survived Boruta. Try lowering the percentile or check data.")

# 5. SHAP importance on surviving features ------------------------------------
X_surv = X[final_features].copy()
# Re‑scale (optional but safe)
scaler_surv = StandardScaler()
X_surv_scaled = scaler_surv.fit_transform(X_surv)

# Train fresh XGBoost for SHAP
xgb_shap = XGBClassifier(
    n_estimators=100,
    max_depth=5,
    learning_rate=0.1,
    objective='multi:softmax',
    num_class=num_classes,
    random_state=42,
    n_jobs=-1
)
xgb_shap.fit(X_surv_scaled, y)

# SHAP explainer
explainer = shap.TreeExplainer(xgb_shap)
shap_values = explainer.shap_values(X_surv_scaled)   # list of arrays (one per class)

# Mean absolute SHAP across all classes and samples
shap_importances = np.mean(np.abs(np.stack(shap_values, axis=0)), axis=(0,1))

importance_df = pd.DataFrame({
    'feature': final_features,
    'shap_importance': shap_importances
})
importance_df.sort_values('shap_importance', ascending=False, inplace=True)
importance_df.reset_index(drop=True, inplace=True)

importance_df.to_csv(OUTPUT_RANKING, index=False)
print(f"Saved {OUTPUT_RANKING} with {len(importance_df)} features.")
print("Top 10:")
print(importance_df.head(10))
