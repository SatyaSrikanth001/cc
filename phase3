#!/usr/bin/env python3
"""
Phase 3: Weighted Consensus Ranking
- Reads the three independent ranking files.
- Converts each method's scores to percentile ranks (0‑1).
- Applies a weighted average:
      Boruta+SHAP: 50%
      RF LOUO:     35%
      Fisher:      15%
- Imputes missing percentiles with 0.5 (neutral).
- Saves full details: all percentile columns, weighted average, and stability std.
"""

import pandas as pd
import numpy as np

# ======================= CONFIGURATION =======================
FILES = {
    'boruta_shap': 'boruta_shap_ranking.csv',
    'fisher': 'fisher_ranking.csv',
    'rf_louo': 'rf_louo_importance.csv'
}

# Weights (must sum to 1)
WEIGHTS = {
    'boruta_shap': 0.50,
    'fisher': 0.15,
    'rf_louo': 0.35
}

MISSING_FILL = 0.5          # neutral percentile for missing features
OUTPUT = 'consensus_ranking.csv'
# =============================================================

# 1. Load each ranking, compute percentile ranks ---------------------------------
ranks = []
for method, path in FILES.items():
    df = pd.read_csv(path)
    # Determine the score column
    if 'shap_importance' in df.columns:
        score_col = 'shap_importance'
    elif 'fisher_score' in df.columns:
        score_col = 'fisher_score'
    else:
        score_col = 'importance'   # RF LOUO

    # Percentile rank (0‑1), higher score -> higher percentile
    df['percentile'] = df[score_col].rank(pct=True)
    df = df[['feature', 'percentile']].rename(columns={'percentile': f'pct_{method}'})
    ranks.append(df)

# 2. Merge on feature (outer join to keep all features from any method) ----------
consensus = ranks[0]
for df in ranks[1:]:
    consensus = consensus.merge(df, on='feature', how='outer')

# 3. Impute missing percentiles with 0.5 (neutral) instead of 0 -----------------
pct_cols = [f'pct_{method}' for method in WEIGHTS.keys()]   # order: boruta_shap, fisher, rf_louo
consensus[pct_cols] = consensus[pct_cols].fillna(MISSING_FILL)

# 4. Weighted average -----------------------------------------------------------
consensus['avg_percentile'] = (
      WEIGHTS['boruta_shap'] * consensus['pct_boruta_shap']
    + WEIGHTS['fisher']      * consensus['pct_fisher']
    + WEIGHTS['rf_louo']     * consensus['pct_rf_louo']
)

# 5. Stability standard deviation (how much the percentiles differ across methods)
consensus['std_percentile'] = consensus[pct_cols].std(axis=1)

# 6. Sort by weighted average descending, then reset index -----------------------
consensus.sort_values('avg_percentile', ascending=False, inplace=True)
consensus.reset_index(drop=True, inplace=True)

# 7. Save the full table ---------------------------------------------------------
consensus.to_csv(OUTPUT, index=False)
print(f"Consensus ranking saved to {OUTPUT}")
print("\nTop 10 features:")
print(consensus[['feature', 'avg_percentile', 'std_percentile']].head(10))
