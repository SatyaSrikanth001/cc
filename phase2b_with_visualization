# 1. DATA LOADING (MODIFIED)
# ============================================================
def load_all_user_data(base_path='./features', user_list=None):
    """Load CSV files for the specified user list only."""
    data = []
    users = []
    if user_list is None:
        # fallback to all files
        user_list = [csv_file.stem.replace('_training_sessions', '')
                     for csv_file in Path(base_path).glob('*_training_sessions.csv')]

    for username in user_list:
        csv_file = Path(base_path) / f'{username}_training_sessions.csv'
        if not csv_file.exists():
            print(f"Warning: {csv_file} not found")
            continue
        try:
            df = pd.read_csv(csv_file)
            df['user'] = username
            data.append(df)
            users.append(username)
            print(f"Loaded {username}: {len(df)} samples")
        except Exception as e:
            print(f"Error loading {csv_file}: {e}")
            continue

    if not data:
        raise FileNotFoundError("No CSV files found for the given user list!")

    combined_df = pd.concat(data, ignore_index=True)
    print(f"\nTotal: {len(combined_df)} samples from {len(users)} users")
    return combined_df, users


def get_numeric_features(df):
    potential_features = [col for col in df.columns if col != 'user']
    numeric_features = []
    for col in potential_features:
        try:
            pd.to_numeric(df[col], errors='raise')
            numeric_features.append(col)
        except (ValueError, TypeError):
            print(f"Skipping non-numeric column: {col} (dtype: {df[col].dtype})")
            continue
    print(f"\nFound {len(numeric_features)} numeric features out of {len(potential_features)} total columns")
    return numeric_features

# ============================================================
# 2. FEATURE SCORING (unchanged)
# ============================================================
def calculate_fisher_score(df, feature_cols):
    scores = {}
    for feature in feature_cols:
        try:
            feature_data = pd.to_numeric(df[feature], errors='coerce')
            if feature_data.isna().all():
                print(f"Warning: Feature '{feature}' contains no valid numeric data")
                continue
            temp_df = pd.DataFrame({'feature': feature_data, 'user': df['user']}).dropna()
            if temp_df.empty:
                continue
            overall_mean = temp_df['feature'].mean()
            user_means = temp_df.groupby('user')['feature'].mean()
            user_counts = temp_df.groupby('user')['feature'].count()
            between_var = np.sum(user_counts * (user_means - overall_mean) ** 2) / len(temp_df)
            within_var = temp_df.groupby('user')['feature'].var().mean()
            if pd.isna(within_var) or within_var == 0:
                within_var = 1e-10
            fisher_score = between_var / (within_var + 1e-10)
            user_stds = temp_df.groupby('user')['feature'].std()
            user_means_for_cv = temp_df.groupby('user')['feature'].mean()
            cv_values = user_stds / (user_means_for_cv + 1e-10)
            cv_mean = cv_values.mean()
            scores[feature] = {
                'fisher_score': fisher_score,
                'between_var': between_var,
                'within_var': within_var,
                'cv_mean': cv_mean,
                'valid_samples': len(temp_df)
            }
        except Exception as e:
            print(f"Error processing feature '{feature}': {e}")
            continue
    if not scores:
        raise ValueError("No valid features found for analysis!")
    return pd.DataFrame(scores).T.sort_values('fisher_score', ascending=False)

