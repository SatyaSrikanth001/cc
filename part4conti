#!/usr/bin/env python3
"""
Phase 1 – Refined Data Cleansing & Pre‑Filtering.
- Loads the 13 development users' training CSVs.
- Removes duplicate columns.
- Drops features with >60% missing values.
- Median‑imputes remaining missing values.
- Drops near‑zero variance features (var < 1e-8).
- Drops one of each pair of highly correlated features (Spearman |ρ| > 0.95).
Outputs:
  cleaned_features.csv (final list of surviving features)
  removed_missing.csv
  removed_low_variance.csv
  removed_correlation.csv
"""

import os, glob, warnings
import pandas as pd
import numpy as np

warnings.filterwarnings('ignore')

DATA_DIR = './features'
PATTERN = '*_training_sessions.csv'
N_DEV_USERS = 13

# Parameters
VARIANCE_THRESHOLD = 1e-8          # near‑zero variance
MISSING_THRESHOLD = 0.6            # drop features missing in >60% of rows
CORRELATION_THRESHOLD = 0.95       # absolute correlation
CORR_METHOD = 'spearman'           # robust to outliers & monotonic relations

# ------------------------------------------------------------------
# 1. Load dev users training data (only the 13 development users)
# ------------------------------------------------------------------
files = sorted(glob.glob(os.path.join(DATA_DIR, PATTERN)))[:N_DEV_USERS]
dfs = []
for f in files:
    df = pd.read_csv(f)
    df.drop(columns=['user'], errors='ignore', inplace=True)
    dfs.append(df)

combined = pd.concat(dfs, ignore_index=True)
print(f"Combined shape: {combined.shape}")

# Keep only numeric columns
combined = combined.select_dtypes(include=[np.number])

# ------------------------------------------------------------------
# 2. Remove duplicate columns (exact copies)
# ------------------------------------------------------------------
duplicate_mask = combined.T.duplicated(keep='first')
duplicate_features = combined.columns[duplicate_mask].tolist()
if duplicate_features:
    combined = combined.loc[:, ~duplicate_mask]
    print(f"Dropped {len(duplicate_features)} duplicate columns.")
    pd.Series(duplicate_features).to_csv('removed_duplicates.csv', index=False, header=['feature'])
else:
    print("No duplicate columns found.")

# ------------------------------------------------------------------
# 3. Drop features with excessive missing values
# ------------------------------------------------------------------
missing_ratio = combined.isna().mean()
cols_to_drop_missing = missing_ratio[missing_ratio > MISSING_THRESHOLD].index.tolist()
combined.drop(columns=cols_to_drop_missing, inplace=True, errors='ignore')
print(f"Dropped {len(cols_to_drop_missing)} columns with >{MISSING_THRESHOLD*100:.0f}% missing.")

pd.Series(cols_to_drop_missing).to_csv('removed_missing.csv', index=False, header=['feature'])

# ------------------------------------------------------------------
# 4. Impute remaining missing values with the median
# ------------------------------------------------------------------
combined = combined.fillna(combined.median())
print("Imputed remaining missing values with column medians.")

# ------------------------------------------------------------------
# 5. Remove zero / near‑zero variance features
# ------------------------------------------------------------------
variances = combined.var()
low_var_cols = variances[variances < VARIANCE_THRESHOLD].index.tolist()
combined.drop(columns=low_var_cols, inplace=True, errors='ignore')
print(f"Dropped {len(low_var_cols)} near‑zero variance features.")

pd.Series(low_var_cols).to_csv('removed_low_variance.csv', index=False, header=['feature'])

# ------------------------------------------------------------------
# 6. Remove highly correlated features (keep the one with higher variance)
# ------------------------------------------------------------------
corr_matrix = combined.corr(method=CORR_METHOD).abs()
upper_tri = corr_matrix.where(np.triu(np.ones(corr_matrix.shape), k=1).astype(bool))

to_drop = set()
for col in upper_tri.columns:
    high_corr = upper_tri[col][upper_tri[col] > CORRELATION_THRESHOLD].index.tolist()
    if not high_corr:
        continue
    for other in high_corr:
        if combined[col].var() < combined[other].var():
            to_drop.add(col)
        else:
            to_drop.add(other)

combined.drop(columns=list(to_drop), inplace=True, errors='ignore')
print(f"Dropped {len(to_drop)} features due to high correlation (|ρ| > {CORRELATION_THRESHOLD}).")

pd.Series(list(to_drop)).to_csv('removed_correlation.csv', index=False, header=['feature'])

# ------------------------------------------------------------------
# 7. Save final surviving feature list
# ------------------------------------------------------------------
surviving_features = combined.columns.tolist()
print(f"Surviving features after cleansing: {len(surviving_features)}")
pd.Series(surviving_features).to_csv('cleaned_features.csv', index=False, header=['feature'])
print("Saved cleaned_features.csv\n")

print("=== Summary of removed features ===")
print(f"Missing (> {MISSING_THRESHOLD*100:.0f}%): {len(cols_to_drop_missing)}")
print(f"Low variance (< {VARIANCE_THRESHOLD}): {len(low_var_cols)}")
print(f"High correlation (> {CORRELATION_THRESHOLD}): {len(to_drop)}")
