#!/usr/bin/env python3
"""
Phase 3 – Weighted Consensus Ranking (refined).
"""

import pandas as pd
import numpy as np

FILES = {
    'boruta_shap': 'boruta_shap_ranking.csv',
    'fisher':      'fisher_ranking.csv',
    'rf_louo':     'rf_louo_importance.csv'
}

WEIGHTS = {
    'boruta_shap': 0.50,
    'fisher':      0.15,
    'rf_louo':     0.35
}

OUTPUT_MASTER = 'consensus_ranking.csv'

ranks = []
for method, path in FILES.items():
    df = pd.read_csv(path)
    if 'shap_importance' in df.columns:
        score_col = 'shap_importance'
    elif 'fisher_score' in df.columns:
        score_col = 'fisher_score'
    else:
        score_col = 'importance'
    df['percentile'] = df[score_col].rank(pct=True)
    df = df[['feature', 'percentile']].rename(columns={'percentile': f'pct_{method}'})
    ranks.append(df)

consensus = ranks[0]
for df in ranks[1:]:
    consensus = consensus.merge(df, on='feature', how='outer')

pct_cols = [c for c in consensus.columns if c.startswith('pct_')]
consensus[pct_cols] = consensus[pct_cols].fillna(0.5)

weights_ordered = [WEIGHTS.get(col.replace('pct_', ''), 0) for col in pct_cols]
weights_ordered = np.array(weights_ordered) / np.sum(weights_ordered)
consensus['avg_percentile'] = consensus[pct_cols].values.dot(weights_ordered)

consensus['std_percentile'] = consensus[pct_cols].std(axis=1)

consensus.sort_values('avg_percentile', ascending=False, inplace=True)
consensus.reset_index(drop=True, inplace=True)
consensus.to_csv(OUTPUT_MASTER, index=False)
print(f"Consensus ranking saved to {OUTPUT_MASTER}")
