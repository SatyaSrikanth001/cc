#!/usr/bin/env python3
"""
Phase 2C: Random Forest importance ranking using Leave-One-User-Out (LOUO).
- Loads the 13 development users only.
- Filters training and test data to the cleaned features from Phase 1.
- Treats label 0 = genuine, 1 = impostor.
- Handles class imbalance via class_weight='balanced'.
- Uses 300 trees for stable feature importance.
- Saves per-fold importances in 'rf_folds/' folder and the final averaged ranking.
"""

import os, glob, warnings
import pandas as pd
import numpy as np
from sklearn.ensemble import RandomForestClassifier
from sklearn.preprocessing import StandardScaler

warnings.filterwarnings('ignore')

# ======================= CONFIGURATION =======================
DATA_DIR = "./features"
CLEANED_FEATURES_FILE = "cleaned_features.csv"
N_DEV_USERS = 13
OUTPUT_AVG_RANKING = "rf_louo_importance.csv"
OUTPUT_FOLDS_DIR = "rf_folds"
# =============================================================

# ------------------------------------------------------------------
# 1. Identify dev users
# ------------------------------------------------------------------
train_files = sorted(glob.glob(os.path.join(DATA_DIR, "*_training_sessions.csv")))
all_users = [os.path.basename(f).replace("_training_sessions.csv", "") for f in train_files]
if len(all_users) < N_DEV_USERS:
    raise ValueError(f"Need at least {N_DEV_USERS} users, found {len(all_users)}")
dev_users = all_users[:N_DEV_USERS]
print(f"Development users: {dev_users}")

# ------------------------------------------------------------------
# 2. Load cleaned feature list
# ------------------------------------------------------------------
cleaned_df = pd.read_csv(CLEANED_FEATURES_FILE)
cleaned_features = cleaned_df['feature'].tolist()
print(f"Cleaned features: {len(cleaned_features)}")

# ------------------------------------------------------------------
# 3. Data loading function (now filters to cleaned features)
# ------------------------------------------------------------------
def load_user(user):
    """Load training and test data for a user, filtering to cleaned features."""
    train_path = os.path.join(DATA_DIR, f"{user}_training_sessions.csv")
    test_path = os.path.join(DATA_DIR, f"{user}_test_sessions.csv")

    train = pd.read_csv(train_path)
    test = pd.read_csv(test_path)

    # Remove non-feature columns
    train.drop(columns=['user'], errors='ignore', inplace=True)
    test.drop(columns=['user'], errors='ignore', inplace=True)

    # Extract labels (assumption: 'label' column, 0 = genuine, 1 = impostor)
    y_test = test['label'].astype(int)
    test.drop(columns=['label'], inplace=True)

    # Keep only cleaned features that exist in the data
    available_train = [f for f in cleaned_features if f in train.columns]
    available_test = [f for f in cleaned_features if f in test.columns]
    # Use only the common set to avoid mismatches
    common_features = list(set(available_train) & set(available_test))
    if not common_features:
        raise RuntimeError(f"No common cleaned features for user {user}")

    train = train[common_features]
    test = test[common_features]

    # Ensure numeric and fill any remaining NaN with median (per column)
    train = train.select_dtypes(include=[np.number])
    test = test.select_dtypes(include=[np.number])
    train = train.fillna(train.median())
    test = test.fillna(test.median())

    return train, test, y_test, common_features

# ------------------------------------------------------------------
# 4. LOUO loop
# ------------------------------------------------------------------
# First, get the global feature list from the first dev user (all users should have the same cleaned columns)
_, _, _, feature_names = load_user(dev_users[0])
print(f"Common features across all users: {len(feature_names)}")

# Create output directory for per-fold importances
os.makedirs(OUTPUT_FOLDS_DIR, exist_ok=True)

importances_sum = np.zeros(len(feature_names))
count = 0

for target_user in dev_users:
    X_list, y_list = [], []
    for other_user in dev_users:
        if other_user == target_user:
            continue
        train_other, test_other, y_test_other, _ = load_user(other_user)

        # Genuine samples from training (label 0)
        X_list.append(train_other.values)
        y_list.append(np.zeros(len(train_other)))

        # Impostor samples from test (label 1)
        imp_mask = y_test_other == 1
        if imp_mask.sum() > 0:
            X_list.append(test_other.values[imp_mask])
            y_list.append(np.ones(imp_mask.sum()))

    if not X_list:
        continue

    X_dev = np.vstack(X_list)
    y_dev = np.hstack(y_list).astype(int)

    # Standardize
    scaler = StandardScaler()
    X_dev_scaled = scaler.fit_transform(X_dev)

    # Train Random Forest with class balancing and more trees
    rf = RandomForestClassifier(
        n_estimators=300,
        class_weight='balanced',
        random_state=42,
        n_jobs=-1
    )
    rf.fit(X_dev_scaled, y_dev)

    # Save per-fold importance (for this target_user)
    fold_importance = rf.feature_importances_
    fold_df = pd.DataFrame({
        'feature': feature_names,
        'importance': fold_importance
    }).sort_values('importance', ascending=False)
    fold_df.to_csv(os.path.join(OUTPUT_FOLDS_DIR, f"rf_importance_{target_user}.csv"), index=False)

    importances_sum += fold_importance
    count += 1

# Average importances across folds
avg_importances = importances_sum / count
importance_df = pd.DataFrame({
    'feature': feature_names,
    'importance': avg_importances
}).sort_values('importance', ascending=False)

importance_df.to_csv(OUTPUT_AVG_RANKING, index=False)
print(f"Saved average RF importance to {OUTPUT_AVG_RANKING}")
print(f"Per-fold importances saved in '{OUTPUT_FOLDS_DIR}/'")
