    # ============================================================
    # NAVIGATION FEATURES
    # ============================================================
    def extract_navigation_features(self, session):
        nav = session.get("navigation_events", [])
        features = {}

        if len(nav) < 2:
            return {
                k: 0.0 for k in [
                    "nav_total_screens",
                    "nav_total_duration",
                    "nav_avg_time_per_screen",
                    "nav_flow_deviation",
                    "nav_back_navigation_count",
                    "nav_unique_screens"
                ]
            }

        timestamps = [e["timestamp"] for e in nav]
        durations = np.diff(timestamps) / 1000.0

        features["nav_total_screens"] = len(nav)
        features["nav_total_duration"] = (timestamps[-1] - timestamps[0]) / 1000.0
        features["nav_avg_time_per_screen"] = np.mean(durations)

        deviation = 0
        for i, e in enumerate(nav):
            if i < len(self.expected_flow):
                if e["to_screen"] != self.expected_flow[i]:
                    deviation += 1
        features["nav_flow_deviation"] = deviation

        back = 0
        for i in range(1, len(nav)):
            prev = nav[i-1]["to_screen"]
            curr = nav[i]["to_screen"]
            if curr in self.expected_flow and prev in self.expected_flow:
                if self.expected_flow.index(curr) < self.expected_flow.index(prev):
                    back += 1
        features["nav_back_navigation_count"] = back

        features["nav_unique_screens"] = len(set([e["to_screen"] for e in nav]))
        return features

    # ============================================================
    # TOUCH FEATURES (updated with swipe geometry)
    # ============================================================
    def extract_touch_features(self, session):
        touches = session.get("touch_events", [])
        features = {}

        if len(touches) < 2:
            # complete default keys, including new swipe geometry
            return {
                k: 0.0 for k in [
                    "touch_count",
                    "touch_duration_mean",
                    "touch_duration_std",
                    "touch_duration_p5",
                    "touch_duration_p95",
                    "touch_duration_iqr",
                    "touch_interval_mean",
                    "touch_interval_std",
                    "touch_interval_p5",
                    "touch_interval_p95",
                    "touch_interval_iqr",
                    "touch_velocity_mean",
                    "touch_velocity_std",
                    "touch_velocity_p5",
                    "touch_velocity_p95",
                    "touch_velocity_iqr",
                    "touch_tap_ratio",
                    "trigraph_flight_mean",
                    "trigraph_flight_std",
                    "trigraph_flight_p5",
                    "trigraph_flight_p95",
                    "trigraph_flight_iqr",
                    "trigraph_rhythm_variance_mean",
                    "trigraph_rhythm_variance_std",
                    # new swipe geometry
                    "swipe_angle_mean",
                    "swipe_angle_std",
                    "swipe_path_mean",
                    "swipe_path_std",
                    "swipe_straightness_mean",
                ]
            }

        screen_w = session.get('device_info', {}).get('screen_width', 1)
        screen_h = session.get('device_info', {}).get('screen_height', 1)

        durations = np.array([t['touch_up_ts'] - t['touch_down_ts'] for t in touches])
        features['touch_duration_mean'] = np.mean(durations)
        features['touch_duration_std'] = np.std(durations)
        features['touch_duration_p5'] = np.percentile(durations, 5)
        features['touch_duration_p95'] = np.percentile(durations, 95)
        features['touch_duration_iqr'] = np.percentile(durations, 75) - np.percentile(durations, 25)
        features['touch_count'] = len(touches)

        intervals = np.diff([t['touch_down_ts'] for t in touches])
        features['touch_interval_mean'] = np.mean(intervals)
        features['touch_interval_std'] = np.std(intervals)
        features['touch_interval_p5'] = np.percentile(intervals, 5)
        features['touch_interval_p95'] = np.percentile(intervals, 95)
        features['touch_interval_iqr'] = np.percentile(intervals, 75) - np.percentile(intervals, 25)

        velocities = []
        for i in range(1, len(touches)):
            x1 = touches[i-1]['x'] / screen_w
            y1 = touches[i-1]['y'] / screen_h
            x2 = touches[i]['x'] / screen_w
            y2 = touches[i]['y'] / screen_h
            dx = x2 - x1
            dy = y2 - y1
            dt = (touches[i]['touch_down_ts'] - touches[i-1]['touch_up_ts']) / 1000.0
            if dt > 1e-6:
                velocities.append(np.sqrt(dx**2 + dy**2) / dt)
        velocities = np.array(velocities)
        if len(velocities) > 0:
            features['touch_velocity_mean'] = np.mean(velocities)
            features['touch_velocity_std'] = np.std(velocities)
            features['touch_velocity_p5'] = np.percentile(velocities, 5)
            features['touch_velocity_p95'] = np.percentile(velocities, 95)
            features['touch_velocity_iqr'] = np.percentile(velocities, 75) - np.percentile(velocities, 25)
        else:
            for k in ['touch_velocity_mean','touch_velocity_std','touch_velocity_p5','touch_velocity_p95','touch_velocity_iqr']:
                features[k] = 0.0

        taps = sum(1 for t in touches if t.get('gesture_type') == 'tap')
        features['touch_tap_ratio'] = taps / len(touches)

        # Trigraph flight time
        if len(touches) >= 3:
            trigraph_flights = []
            rhythm_variances = []
            for i in range(len(touches) - 2):
                tri_flight = touches[i+2]['touch_down_ts'] - touches[i]['touch_up_ts']
                if tri_flight >= 0:
                    trigraph_flights.append(tri_flight)
                f1 = touches[i+1]['touch_down_ts'] - touches[i]['touch_up_ts']
                f2 = touches[i+2]['touch_down_ts'] - touches[i+1]['touch_up_ts']
                if f1 >= 0 and f2 >= 0:
                    rhythm_variances.append(np.var([f1, f2]))
            if trigraph_flights:
                trigraph_flights = np.array(trigraph_flights)
                features['trigraph_flight_mean'] = np.mean(trigraph_flights)
                features['trigraph_flight_std'] = np.std(trigraph_flights)
                features['trigraph_flight_p5'] = np.percentile(trigraph_flights, 5)
                features['trigraph_flight_p95'] = np.percentile(trigraph_flights, 95)
                features['trigraph_flight_iqr'] = np.percentile(trigraph_flights, 75) - np.percentile(trigraph_flights, 25)
            else:
                for k in ['trigraph_flight_mean','trigraph_flight_std','trigraph_flight_p5','trigraph_flight_p95','trigraph_flight_iqr']:
                    features[k] = 0.0
            if rhythm_variances:
                features['trigraph_rhythm_variance_mean'] = np.mean(rhythm_variances)
                features['trigraph_rhythm_variance_std'] = np.std(rhythm_variances)
            else:
                features['trigraph_rhythm_variance_mean'] = 0.0
                features['trigraph_rhythm_variance_std'] = 0.0
        else:
            for k in ['trigraph_flight_mean','trigraph_flight_std','trigraph_flight_p5','trigraph_flight_p95','trigraph_flight_iqr',
                      'trigraph_rhythm_variance_mean','trigraph_rhythm_variance_std']:
                features[k] = 0.0

        # Add swipe geometry features
        features.update(self._extract_swipe_geometry(touches, screen_w, screen_h))

        return features

    def _extract_swipe_geometry(self, touches, screen_w, screen_h):
        """Swipe angle, path length, straightness."""
        angles = []
        path_lengths = []
        straightness_vals = []
        for t in touches:
            x1 = t.get('x_down', t.get('x', 0.0)) / screen_w
            y1 = t.get('y_down', t.get('y', 0.0)) / screen_h
            x2 = t.get('x_up', t.get('x', 0.0)) / screen_w
            y2 = t.get('y_up', t.get('y', 0.0)) / screen_h
            dx = x2 - x1
            dy = y2 - y1
            angle = np.arctan2(dy, dx)
            angles.append(angle)
            path_len = np.sqrt(dx**2 + dy**2)
            path_lengths.append(path_len)
            # without raw touch-move points, straightness is 1.0
            straightness_vals.append(1.0)

        features = {}
        if angles:
            features['swipe_angle_mean'] = float(np.mean(angles))
            features['swipe_angle_std'] = float(np.std(angles))
            features['swipe_path_mean'] = float(np.mean(path_lengths))
            features['swipe_path_std'] = float(np.std(path_lengths))
            features['swipe_straightness_mean'] = float(np.mean(straightness_vals))
        else:
            for k in ['swipe_angle_mean','swipe_angle_std','swipe_path_mean','swipe_path_std','swipe_straightness_mean']:
                features[k] = 0.0
        return features

    # ============================================================
    # LOW‑PASS FILTER
    # ============================================================
    def lowpass_filter(self, data, cutoff, fs, order=3):
        nyq = 0.5 * fs
        normal_cutoff = cutoff / nyq
        b, a = butter(order, normal_cutoff, btype='low')
        return filtfilt(b, a, data)

