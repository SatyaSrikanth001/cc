    def extract_acc_features(self, session):
        sensors = session.get('sensor_events', [])
        acc_x, acc_y, acc_z = [], [], []
        for e in sensors:
            acc = e.get('accelerometer')
            if acc:
                x = acc.get('x')
                y = acc.get('y')
                z = acc.get('z')
                if x is not None and y is not None and z is not None:
                    acc_x.append(x)
                    acc_y.append(y)
                    acc_z.append(z)
        if len(acc_x) < 5:
            return {
                'acc_magnitude_mean': 0.0,
                'acc_magnitude_std': 0.0,
                'acc_jitter': 0.0,
                'acc_skew': 0.0,
                'acc_kurtosis': 0.0,
                'acc_x_mean': 0.0
            }
        acc_x = np.array(acc_x)
        acc_y = np.array(acc_y)
        acc_z = np.array(acc_z)
        mag = np.sqrt(acc_x**2 + acc_y**2 + acc_z**2)
        jerk = np.diff(mag)
        return {
            'acc_magnitude_mean': np.mean(mag),
            'acc_magnitude_std': np.std(mag),
            'acc_magnitude_jerk_mean': np.mean(jerk),
            'acc_magnitude_jerk_std': np.std(jerk),
            'acc_magnitude_jerk_p5': np.percentile(jerk, 5),
            'acc_magnitude_jerk_p95': np.percentile(jerk, 95),
            'acc_magnitude_jerk_iqr': np.percentile(jerk, 75) - np.percentile(jerk, 25),
            'acc_jitter': np.mean(np.abs(np.diff(mag))),
            'acc_skew': skew(mag),
            'acc_kurtosis': kurtosis(mag),
            'acc_x_mean': np.mean(acc_x),
            'acc_y_mean': np.mean(acc_y),
            'acc_z_mean': np.mean(acc_z),
            'acc_x_std': np.std(acc_x),
            'acc_y_std': np.std(acc_y),
            'acc_z_std': np.std(acc_z),
            'acc_x_skew': skew(acc_x),
            'acc_y_skew': skew(acc_y),
            'acc_z_skew': skew(acc_z),
            'acc_x_kurtosis': kurtosis(acc_x),
            'acc_y_kurtosis': kurtosis(acc_y),
            'acc_z_kurtosis': kurtosis(acc_z),
            'acc_x_p5': np.percentile(acc_x, 5),
            'acc_x_p95': np.percentile(acc_x, 95),
            'acc_y_p5': np.percentile(acc_y, 5),
            'acc_y_p95': np.percentile(acc_y, 95),
            'acc_z_p5': np.percentile(acc_z, 5),
            'acc_z_p95': np.percentile(acc_z, 95),
            'acc_x_p50': np.percentile(acc_x, 50),
            'acc_y_p50': np.percentile(acc_y, 50),
            'acc_z_p50': np.percentile(acc_z, 50),
            'acc_x_iqr': np.percentile(acc_x, 75) - np.percentile(acc_x, 25),
            'acc_y_iqr': np.percentile(acc_y, 75) - np.percentile(acc_y, 25),
            'acc_z_iqr': np.percentile(acc_z, 75) - np.percentile(acc_z, 25),
        }

    # ============================================================
    # ACCELEROMETER FEATURES (magnitude windowing)
    # ============================================================
    def extract_acc_features_mag_window(self, session):
        sensors = sorted(session.get('sensor_events', []), key=lambda e: e.get('timestamp', 0))
        timestamps, acc_x, acc_y, acc_z = [], [], [], []
        for e in sensors:
            acc = e.get('accelerometer')
            if not acc: continue
            x, y, z = acc.get('x'), acc.get('y'), acc.get('z')
            if x is not None and y is not None and z is not None and np.isfinite(x) and np.isfinite(y) and np.isfinite(z):
                timestamps.append(e.get('timestamp'))
                acc_x.append(x); acc_y.append(y); acc_z.append(z)
        if len(acc_x) < 20: return {}
        timestamps = np.array(timestamps)
        acc_x, acc_y, acc_z = np.array(acc_x, dtype=np.float32), np.array(acc_y, dtype=np.float32), np.array(acc_z, dtype=np.float32)
        fs = self._estimate_sampling_rate(sensors)
        fs = np.clip(fs, 10, 200)
        cutoff = min(20, fs*0.4)
        acc_x = self.lowpass_filter(acc_x, cutoff, fs)
        acc_y = self.lowpass_filter(acc_y, cutoff, fs)
        acc_z = self.lowpass_filter(acc_z, cutoff, fs)
        gravity_window = max(5, int(fs))
        gravity_x = uniform_filter1d(acc_x, size=gravity_window)
        gravity_y = uniform_filter1d(acc_y, size=gravity_window)
        gravity_z = uniform_filter1d(acc_z, size=gravity_window)
        lin_x, lin_y, lin_z = acc_x - gravity_x, acc_y - gravity_y, acc_z - gravity_z
        mag = np.sqrt(lin_x**2 + lin_y**2 + lin_z**2)
        window_size = int(5*fs)
        stride = int(window_size*0.5)
        if len(mag) < window_size: return {}
        window_features = []
        for start in range(0, len(mag)-window_size+1, stride):
            end = start + window_size
            wx, wy, wz, wm = lin_x[start:end], lin_y[start:end], lin_z[start:end], mag[start:end]
            wt = timestamps[start:end]
            dt = np.diff(wt)/1000.0
            dt[dt<=0] = 1e-3
            features = {}
            for axis_name, signal in [('x',wx),('y',wy),('z',wz),('mag',wm)]:
                features[f'{axis_name}_mean'] = np.mean(signal)
                features[f'{axis_name}_std'] = np.std(signal)
                features[f'{axis_name}_skew'] = skew(signal)
                features[f'{axis_name}_kurtosis'] = kurtosis(signal)
                features[f'{axis_name}_p5'] = np.percentile(signal,5)
                features[f'{axis_name}_p50'] = np.percentile(signal,50)
                features[f'{axis_name}_p95'] = np.percentile(signal,95)
                features[f'{axis_name}_iqr'] = np.percentile(signal,75)-np.percentile(signal,25)
                features[f'{axis_name}_energy'] = np.sum(signal**2)/len(signal)
                features[f'{axis_name}_rms'] = np.sqrt(np.mean(signal**2))
                jerk = np.diff(signal)/dt
                features[f'{axis_name}_jerk_mean'] = np.mean(jerk)
                features[f'{axis_name}_jerk_std'] = np.std(jerk)
                features[f'{axis_name}_jerk_p95'] = np.percentile(jerk,95)
            # SMA and correlations outside axis loop
            features['sma'] = np.sum(np.abs(wx)+np.abs(wy)+np.abs(wz))/len(wm)
            features['xy_corr'] = np.corrcoef(wx,wy)[0,1]
            features['xz_corr'] = np.corrcoef(wx,wz)[0,1]
            features['yz_corr'] = np.corrcoef(wy,wz)[0,1]
            window_features.append(features)
        # aggregate
        final_features = {}
        for key in window_features[0].keys():
            vals = [w[key] for w in window_features]
            final_features[f'acc_{key}_mean'] = np.mean(vals)
            final_features[f'acc_{key}_std'] = np.std(vals)
        return final_features

    # ============================================================
    # GYROSCOPE FEATURES (basic + wavelet)
    # ============================================================
    def extract_gyro_features(self, session):
        sensors = session.get('sensor_events', [])
        gx, gy, gz = [], [], []
        for s in sensors:
            gyro = s.get('gyroscope')
            if gyro:
                x, y, z = gyro.get('x'), gyro.get('y'), gyro.get('z')
                if x is not None and y is not None and z is not None:
                    gx.append(x); gy.append(y); gz.append(z)
        if len(gx) < 5:
            return {'gyro_magnitude_mean':0.0, 'gyro_magnitude_std':0.0, 'gyro_jitter':0.0}
        gx, gy, gz = np.array(gx), np.array(gy), np.array(gz)
        mag = np.sqrt(gx**2 + gy**2 + gz**2)
        # wavelet features
        wavelet = 'db4'; level = 1
        gx_wavelet = pywt.wavedec(gx, wavelet, level=level)
        gy_wavelet = pywt.wavedec(gy, wavelet, level=level)
        gz_wavelet = pywt.wavedec(gz, wavelet, level=level)
        def wavelet_stats(coeffs, prefix):
            feats = {}
            for i, c in enumerate(coeffs):
                suffix = "A" if i==0 else f"D{level - i + 1}"
                feats[f'{prefix}_wavelet_{suffix}_mean'] = np.mean(c)
                feats[f'{prefix}_wavelet_{suffix}_std'] = np.std(c)
                feats[f'{prefix}_wavelet_{suffix}_energy'] = np.sum(c**2)
                feats[f'{prefix}_wavelet_{suffix}_max'] = np.max(np.abs(c))
            return feats
        wavelet_features = {**wavelet_stats(gx_wavelet,'gyro_x'),
                            **wavelet_stats(gy_wavelet,'gyro_y'),
                            **wavelet_stats(gz_wavelet,'gyro_z')}
        return {
            'gyro_magnitude_mean': np.mean(mag),
            'gyro_magnitude_std': np.std(mag),
            'gyro_magnitude_p05': np.percentile(mag,5),
            'gyro_magnitude_p95': np.percentile(mag,95),
            'gyro_magnitude_p25': np.percentile(mag,25),
            'gyro_magnitude_p75': np.percentile(mag,75),
            'gyro_jitter': np.mean(np.abs(np.diff(mag))),
            'gyro_skew': skew(mag),
            'gyro_kurtosis': kurtosis(mag),
            'gyro_x_mean': np.mean(gx),
            'gyro_x_std': np.std(gx),
            'gyro_y_mean': np.mean(gy),
            'gyro_y_std': np.std(gy),
            'gyro_z_mean': np.mean(gz),
            'gyro_z_std': np.std(gz),
            'gyro_x_iqr': np.percentile(gx,75)-np.percentile(gx,25),
            'gyro_y_iqr': np.percentile(gy,75)-np.percentile(gy,25),
            'gyro_z_iqr': np.percentile(gz,75)-np.percentile(gz,25),
            'gyro_x_p05': np.percentile(gx,5),
            'gyro_x_p95': np.percentile(gx,95),
            'gyro_y_p05': np.percentile(gy,5),
            'gyro_y_p95': np.percentile(gy,95),
            'gyro_z_p05': np.percentile(gz,5),
            'gyro_z_p95': np.percentile(gz,95),
            'gyro_x_skew': skew(gx),
            'gyro_y_skew': skew(gy),
            'gyro_z_skew': skew(gz),
            'gyro_x_kurt': kurtosis(gx),
            'gyro_y_kurt': kurtosis(gy),
            'gyro_z_kurt': kurtosis(gz),
            **wavelet_features
        }

