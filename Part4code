class SessionPipeline:
    def __init__(self, filepath):
        self.filepath = filepath
        self.extractor = SessionLevelFeatureExtractor()

    def load_sessions(self):
        with open(self.filepath) as f:
            data = json.load(f)
        sessions = data['data']['sessions']
        user_id = data['data']['profile']['user_id']
        sessions = list(reversed(sessions))
        return sessions, user_id

    def split_sessions(self, sessions):
        # (as previously defined, with user‑specific slices)
        # For brevity, omitted here but must be included in full
        pass

    def extract_features(self, sessions, centroids, medoids, label_type=None):
        rows = []
        for s in sessions:
            features = self.extractor.extract_session_features(s, centroids=centroids, medoids=medoids)
            if label_type:
                features['test_type'] = label_type
            rows.append(features)
        return pd.DataFrame(rows)

    def load_dtw_templates(self, user_id, template_dir="templates"):
        path = os.path.join(template_dir, f"{user_id}_dtw_templates.pkl")
        if not os.path.exists(path):
            print(f"[WARN] DTW template missing: {path}")
            return None, None
        with open(path, "rb") as f:
            data = pickle.load(f)
        return data["centroids"], data["medoids"]

    def run(self, output_dir="./features/v2"):
        os.makedirs(output_dir, exist_ok=True)
        sessions, user_id = self.load_sessions()
        train_g, test_g, test_i = self.split_sessions(sessions)
        print("\n Loading DTW templates...")
        centroids, medoids = self.load_dtw_templates(user_id)
        if centroids is None:
            raise ValueError(f"DTW templates not found for user {user_id}")
        print("\n Extracting training features...")
        train_df = self.extract_features(train_g, centroids, medoids)
        print(" Extracting testing (genuine)...")
        test_g_df = self.extract_features(test_g, centroids, medoids, label_type='genuine')
        print(" Extracting testing (impostor)...")
        test_i_df = self.extract_features(test_i, centroids, medoids, label_type='impostor')
        test_df = pd.concat([test_g_df, test_i_df], ignore_index=True)
        train_path = f"{output_dir}/{user_id}_training_sessions.csv"
        test_path = f"{output_dir}/{user_id}_testing_sessions.csv"
        train_df.to_csv(train_path, index=False)
        test_df.to_csv(test_path, index=False)
        print(f"\n SAVED {train_path} and {test_path}")
        return train_path, test_path

