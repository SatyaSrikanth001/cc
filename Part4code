    # ============================================================
    # TOUCH SENSOR FEATURES (self‑engineered)
    # ============================================================
    def extract_touch_sensor_features(self, session):
        touches = session.get('touch_events', [])
        sensors = session.get('sensor_events', [])

        default_keys = [
            "touch_acc_x_mean", "touch_acc_x_std", "touch_acc_x_p05", "touch_acc_x_p95", "touch_acc_x_iqr",
            "touch_acc_y_mean", "touch_acc_y_std", "touch_acc_y_p05", "touch_acc_y_p95", "touch_acc_y_iqr",
            "touch_acc_z_mean", "touch_acc_z_std", "touch_acc_z_p05", "touch_acc_z_p95", "touch_acc_z_iqr",
            "touch_gyro_x_mean", "touch_gyro_x_std", "touch_gyro_x_p05", "touch_gyro_x_p95", "touch_gyro_x_iqr",
            "touch_gyro_y_mean", "touch_gyro_y_std", "touch_gyro_y_p05", "touch_gyro_y_p95", "touch_gyro_y_iqr",
            "touch_gyro_z_mean", "touch_gyro_z_std", "touch_gyro_z_p05", "touch_gyro_z_p95", "touch_gyro_z_iqr",
        ]
        if len(touches) == 0 or len(sensors) == 0:
            return {k: 0.0 for k in default_keys}

        sensor_ts = []
        acc_x, acc_y, acc_z = [], [], []
        gyro_x, gyro_y, gyro_z = [], [], []

        for s in sensors:
            ts = s.get('timestamp')
            if ts is None: continue
            sensor_ts.append(ts)
            acc = s.get('accelerometer')
            if acc and acc.get('x') is not None:
                acc_x.append(acc['x']); acc_y.append(acc['y']); acc_z.append(acc['z'])
            else:
                acc_x.append(np.nan); acc_y.append(np.nan); acc_z.append(np.nan)
            gyro = s.get('gyroscope')
            if gyro and gyro.get('x') is not None:
                gyro_x.append(gyro['x']); gyro_y.append(gyro['y']); gyro_z.append(gyro['z'])
            else:
                gyro_x.append(np.nan); gyro_y.append(np.nan); gyro_z.append(np.nan)

        sensor_ts = np.array(sensor_ts)
        acc_x, acc_y, acc_z = map(np.array, [acc_x, acc_y, acc_z])
        gyro_x, gyro_y, gyro_z = map(np.array, [gyro_x, gyro_y, gyro_z])

        tx_acc_x, tx_acc_y, tx_acc_z = [], [], []
        tx_gyro_x, tx_gyro_y, tx_gyro_z = [], [], []

        WINDOW = 100  # ms
        for t in touches:
            t_ts = t['touch_down_ts']
            mask = (sensor_ts >= t_ts - WINDOW) & (sensor_ts <= t_ts + WINDOW)
            if np.any(mask):
                tx_acc_x.extend(acc_x[mask]); tx_acc_y.extend(acc_y[mask]); tx_acc_z.extend(acc_z[mask])
                tx_gyro_x.extend(gyro_x[mask]); tx_gyro_y.extend(gyro_y[mask]); tx_gyro_z.extend(gyro_z[mask])

        # accelerometer near touch mag
        tx_acc_x = np.array(tx_acc_x, dtype=np.float64); tx_acc_y = np.array(tx_acc_y, dtype=np.float64); tx_acc_z = np.array(tx_acc_z, dtype=np.float64)
        acc_mask = ~np.isnan(tx_acc_x) & ~np.isnan(tx_acc_y) & ~np.isnan(tx_acc_z)
        touch_acc_mag = np.sqrt(tx_acc_x**2 + tx_acc_y**2 + tx_acc_z**2)

        tx_gyro_x = np.array(tx_gyro_x, dtype=np.float64); tx_gyro_y = np.array(tx_gyro_y, dtype=np.float64); tx_gyro_z = np.array(tx_gyro_z, dtype=np.float64)
        gyro_mask = ~np.isnan(tx_gyro_x) & ~np.isnan(tx_gyro_y) & ~np.isnan(tx_gyro_z)
        touch_gyro_mag = np.sqrt(tx_gyro_x**2 + tx_gyro_y**2 + tx_gyro_z**2)

        def compute_stats(arr, prefix):
            arr = np.array(arr, dtype=np.float64)
            arr = arr[~np.isnan(arr)]
            if len(arr) < 5:
                return {f'{prefix}_mean': 0.0, f'{prefix}_std': 0.0, f'{prefix}_variance': 0.0,
                        f'{prefix}_p05': 0.0, f'{prefix}_p95': 0.0, f'{prefix}_iqr': 0.0}
            if prefix == 'touch_acc_mag' or prefix == 'touch_gyro_mag':
                return {f'{prefix}_mean': np.mean(arr), f'{prefix}_std': np.std(arr), f'{prefix}_variance': np.var(arr),
                        f'{prefix}_p05': np.percentile(arr, 5), f'{prefix}_p95': np.percentile(arr, 95),
                        f'{prefix}_iqr': np.percentile(arr, 75) - np.percentile(arr, 25)}
            else:
                return {f'{prefix}_mean': np.mean(arr), f'{prefix}_std': np.std(arr), f'{prefix}_variance': np.var(arr),
                        f'{prefix}_p05': np.percentile(arr, 5), f'{prefix}_p95': np.percentile(arr, 95),
                        f'{prefix}_iqr': np.percentile(arr, 75) - np.percentile(arr, 25)}

        def safe_corr(a, b):
            a = np.array(a, dtype=np.float64); b = np.array(b, dtype=np.float64)
            mask = ~np.isnan(a) & ~np.isnan(b)
            a, b = a[mask], b[mask]
            if len(a) < 5 or np.std(a) == 0 or np.std(b) == 0:
                return 0.0
            return np.corrcoef(a, b)[0, 1]

        features = {}
        features.update(compute_stats(tx_acc_x, 'touch_acc_x'))
        features.update(compute_stats(tx_acc_y, 'touch_acc_y'))
        features.update(compute_stats(tx_acc_z, 'touch_acc_z'))
        features.update(compute_stats(touch_acc_mag, 'touch_acc_mag'))
        features.update(compute_stats(tx_gyro_x, 'touch_gyro_x'))
        features.update(compute_stats(tx_gyro_y, 'touch_gyro_y'))
        features.update(compute_stats(tx_gyro_z, 'touch_gyro_z'))
        features.update(compute_stats(touch_gyro_mag, 'touch_gyro_mag'))

        features.update({
            'touch_acc_corr_xy': safe_corr(tx_acc_x, tx_acc_y),
            'touch_acc_corr_xz': safe_corr(tx_acc_x, tx_acc_z),
            'touch_acc_corr_yz': safe_corr(tx_acc_y, tx_acc_z),
            'touch_gyro_corr_xy': safe_corr(tx_gyro_x, tx_gyro_y),
            'touch_gyro_corr_xz': safe_corr(tx_gyro_x, tx_gyro_z),
            'touch_gyro_corr_yz': safe_corr(tx_gyro_y, tx_gyro_z),
        })
        return features

    # ============================================================
    # FUSED TOUCH SENSOR FEATURES (pitch/roll during touch)
    # ============================================================
    def extract_fused_touch_sensor_features(self, session):
        touches = session.get("touch_events", [])
        sensor_events = session.get("sensor_events", [])
        features = {}
        if len(touches) < 2 or len(sensor_events) < 2:
            return {}

        orientation = []
        for s in sensor_events:
            acc = s.get("accelerometer")
            gyro = s.get("gyroscope") or {}
            if not acc: continue
            ax, ay, az = acc.get("x"), acc.get("y"), acc.get("z")
            if ax is None or ay is None or az is None: continue
            try: ax, ay, az = float(ax), float(ay), float(az)
            except: continue
            denom = np.sqrt(ay**2 + az**2)
            pitch = np.arctan(-ax / denom if denom != 0 else 1e-6)
            roll = np.arctan(ay / az if az != 0 else 1e-6)
            gx, gy, gz = gyro.get("x", 0.0), gyro.get("y", 0.0), gyro.get("z", 0.0)
            try: gx, gy, gz = float(gx), float(gy), float(gz)
            except: gx, gy, gz = 0.0, 0.0, 0.0
            gyro_mag = np.sqrt(gx**2 + gy**2 + gz**2)
            ts = s.get("timestamp")
            if ts is None: continue
            orientation.append({"ts": ts, "pitch": pitch, "roll": roll, "gyro": gyro_mag})
        orientation.sort(key=lambda x: x["ts"])

        def extract_window(start_ts, end_ts):
            window = [o for o in orientation if start_ts <= o["ts"] <= end_ts]
            if len(window) < 2: return None
            pitch = np.array([w["pitch"] for w in window])
            roll = np.array([w["roll"] for w in window])
            gyro = np.array([w["gyro"] for w in window])
            if len(pitch)==0 or len(roll)==0: return None
            return {
                "pitch_mean": np.mean(pitch), "pitch_std": np.std(pitch),
                "roll_mean": np.mean(roll), "roll_std": np.std(roll),
                "gyro_mean": np.mean(gyro), "gyro_std": np.std(gyro),
                "pitch_ratio": np.std(pitch) / (abs(np.mean(pitch)) + 1e-6),
                "roll_ratio": np.std(roll) / (abs(np.mean(roll)) + 1e-6),
            }

        touch_features = []
        for t in touches:
            start = t.get("touch_down_ts"); end = t.get("touch_up_ts")
            if start is None or end is None: continue
            feat = extract_window(start-100, end+100)
            if feat is not None: touch_features.append(feat)
        if len(touch_features) < 2: return {}

        features["touch_count"] = len(touch_features)
        features["pitch_mean"] = np.mean([t["pitch_mean"] for t in touch_features])
        features["roll_mean"] = np.mean([t["roll_mean"] for t in touch_features])
        features["pitch_ratio_mean"] = np.mean([t["pitch_ratio"] for t in touch_features])
        features["roll_ratio_mean"] = np.mean([t["roll_ratio"] for t in touch_features])
        features["gyro_mean"] = np.mean([t["gyro_mean"] for t in touch_features])
        features["gyro_std"] = np.std([t["gyro_std"] for t in touch_features])

        pitch_diffs = [touch_features[i+1]["pitch_mean"] - touch_features[i]["pitch_mean"] for i in range(len(touch_features)-1)]
        roll_diffs = [touch_features[i+1]["roll_mean"] - touch_features[i]["roll_mean"] for i in range(len(touch_features)-1)]
        gyro_diffs = [touch_features[i+1]["gyro_mean"] - touch_features[i]["gyro_mean"] for i in range(len(touch_features)-1)]
        features["pitch_digraph_mean"] = np.mean(pitch_diffs); features["pitch_digraph_std"] = np.std(pitch_diffs)
        features["roll_digraph_mean"] = np.mean(roll_diffs); features["roll_digraph_std"] = np.std(roll_diffs)
        features["gyro_digraph_mean"] = np.mean(gyro_diffs)

        pitch_tri = [touch_features[i+2]["pitch_mean"] - touch_features[i]["pitch_mean"] for i in range(len(touch_features)-2)]
        roll_tri = [touch_features[i+2]["roll_mean"] - touch_features[i]["roll_mean"] for i in range(len(touch_features)-2)]
        features["pitch_trigraph_mean"] = np.mean(pitch_tri); features["pitch_trigraph_std"] = np.std(pitch_tri)
        features["roll_trigraph_mean"] = np.mean(roll_tri); features["roll_trigraph_std"] = np.std(roll_tri)
        return features

